# ============================================================
# EvilTwin Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the required values.
# Never commit the actual .env file to version control.

# ----------------------------------------------------------
# REQUIRED — application will refuse to start without these
# ----------------------------------------------------------

# PostgreSQL password (must match POSTGRES_PASSWORD in docker-compose.yml)
POSTGRES_PASSWORD=changeme

# Secret key used to sign JWT tokens.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Shared secret for validating Canary token webhook HMAC signatures
CANARY_WEBHOOK_SECRET=change-me-in-production

# ----------------------------------------------------------
# OPTIONAL — leave blank to disable the corresponding feature
# ----------------------------------------------------------

# IPInfo.io API token for IP geolocation (https://ipinfo.io)
IPINFO_TOKEN=

# AbuseIPDB API key for threat intelligence lookups (https://www.abuseipdb.com)
ABUSEIPDB_API_KEY=

# Splunk HTTP Event Collector endpoint and token
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# LLM (language-model) integration for AI-assisted threat narration
# Set LLM_BASE_URL to an OpenAI-compatible endpoint (e.g. local Ollama, Azure OpenAI)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
