# ============================================================================
# EvilTwin Root Environment Template
# ============================================================================
# Copy this file to .env in the repository root before running:
#   cp .env.example .env
#   docker compose up --build -d
#
# The required values below are the only ones you must set for the demo stack.
# Everything else can stay at its default unless you are customizing the setup.

# ============================================================================
# REQUIRED FOR CLONE-AND-RUN
# ============================================================================

# PostgreSQL password used by the compose stack.
POSTGRES_PASSWORD=changeme

# JWT signing secret for dashboard authentication.
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Shared HMAC secret for Canary webhook validation.
# Generate one with: openssl rand -hex 32
CANARY_WEBHOOK_SECRET=change-me-in-production


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eviltwin
POSTGRES_USER=eviltwin


# ============================================================================
# SDN / HONEYPOT ROUTING
# ============================================================================

RYU_REST_URL=http://ryu:8080
HONEYPOT_IP=10.0.2.10
REAL_NET_CIDR=10.0.1.0/24
THREAT_REDIRECT_THRESHOLD=2


# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

MODEL_PATH=/app/ai/model.pkl
PRE_SESSION_MODEL_PATH=/app/ai/pre_session_model.pkl
SCORE_CACHE_TTL=300


# ============================================================================
# OPTIONAL EXTERNAL TOKENS
# ============================================================================

# Leave blank to disable IP enrichment and reputation lookups.
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=


# ============================================================================
# OPTIONAL SPLUNK FORWARDING
# ============================================================================

SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=


# ============================================================================
# AUTH / API SETTINGS
# ============================================================================

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CANARY_WEBHOOK_TOLERANCE_SECONDS=300


# ============================================================================
# OPTIONAL LLM / INCIDENT NARRATIVES
# ============================================================================

# Leave blank to disable AI narrative features. Works with OpenAI-compatible APIs
# (OpenAI, DeepSeek, Ollama, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2


# ============================================================================
# GATEWAY SSH PROXY CONFIGURATION
# ============================================================================

GATEWAY_BACKEND_URL=http://backend:8000
GATEWAY_PORT=22
GATEWAY_BACKEND_TIMEOUT=2.0
AUTH_COLLECT_WINDOW_S=5.0
GATEWAY_WHITELIST_CIDRS=
PENTEST_CIDRS=
SERVICE_ACCOUNT_USERNAME_PATTERNS=

# Real server (for "real" decisions)
REAL_SSH_HOST=dummy-real
REAL_SSH_PORT=22
REAL_SSH_USER=gateway
REAL_SSH_PASSWORD=gateway

# Honeypot (for "honeypot" decisions)
GATEWAY_HONEYPOT_HOST=cowrie
GATEWAY_HONEYPOT_PORT=2222

# SDN notification URL
SDN_REST_URL=http://ryu:8080


# ============================================================================
# HTTP GATEWAY (per-IP routing)
# ============================================================================

HTTP_GATEWAY_PORT=8888
ROUTING_BACKEND_URL=http://backend:8000
REAL_HTTP_URL=http://dummy-real:8080
INGEST_BACKEND_URL=http://backend:8000
ROUTING_API_KEY=
ROUTING_BYPASS_IPS=127.0.0.1,::1

# Credential gate for the real server (hidden by default; only these creds open it).
# Mirror of the SSH gateway's real/eviltwin fast-path. SECRET_KEY signs the auth cookie.
REAL_HTTP_USER=real
REAL_HTTP_PASSWORD=eviltwin
AUTH_COOKIE_NAME=et_sess
AUTH_TTL_S=3600


# ============================================================================
# TRIPWIRE (CANARY TOKEN) CONFIGURATION
# ============================================================================
# Canary tokens are arranged as a graduated "level" ladder. Each level lives on
# a different surface whose access difficulty matches its threat difficulty:
#   L0 open HTTP listing (tripwire 8082) → L1 unlisted HTTP (Dionaea 8081) →
#   L2 anon FTP (Dionaea 2121) → L3 leaked /.git (tripwire 8082) →
#   L4 SSH /tmp (Cowrie 2222) → L5 SSH /root/.ssh (Cowrie 2222).
#
# The tripwire serves only L0 + L3 (see TRIPWIRE_TOKEN_MAP). L1/L2/L4/L5 fire
# from backend honeypot-log detection (services/canary.py).

# Default token for any open browse of the tripwire (the benign Public Web Bug).
TRIPWIRE_TOKEN_ID=095a6bfa-9fbe-4a1f-b4fb-a1afa971cd98

# Path → token map for the tripwire HTTP server. "default" handles open browsing.
TRIPWIRE_TOKEN_MAP={"default":"095a6bfa-9fbe-4a1f-b4fb-a1afa971cd98","/.env.production":"b1d9f0c2-3a4e-4c7b-9f21-5d6e7a8b9c0d","/.git/config":"b1d9f0c2-3a4e-4c7b-9f21-5d6e7a8b9c0d","/.git/HEAD":"b1d9f0c2-3a4e-4c7b-9f21-5d6e7a8b9c0d","/.git/logs/HEAD":"b1d9f0c2-3a4e-4c7b-9f21-5d6e7a8b9c0d"}

# Optional: override honeypot-side bait detection (JSON {"substring":"token-uuid"}).
# Empty = built-in patterns (passwords.txt, aws_credentials, database_backup.sql, id_rsa).
CANARY_BAIT_MAP=
CANARY_INGEST_COOLDOWN_SECONDS=30


# ============================================================================
# FRONTEND RUNTIME URLS
# ============================================================================

VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/alerts


# ============================================================================
# DEMO ACCOUNT BOOTSTRAP
# ============================================================================

# Disabled by default. Set to true to seed demo data on first startup.
DEMO_BOOTSTRAP=false
DEMO_USER_EMAIL=analyst@eviltwin.local
DEMO_USER_PASSWORD=eviltwin-demo
DEMO_USER_ROLE=analyst


# ============================================================================
# OPTIONAL DIONAEA DEMO PORT OVERRIDES
# ============================================================================

DIONAEA_FTP_PORT=2121
DIONAEA_HTTP_PORT=8081
DIONAEA_SMB_PORT=1445
DIONAEA_MSSQL_PORT=11433


# ============================================================================
# OPTIONAL APP OVERRIDES
# ============================================================================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
DEBUG=false
